## Widget Gallery Titles
accordion = أكورديون
    .description = يعرض الأكورديون قائمة من الرؤوس التي يمكن توسيعها واحدة تلو الأخرى للكشف عن المحتوى.
avatar = صورة رمزية
    .description = تُستخدم الصورة الرمزية لتمثيل شخص أو كيان بشكل مرئي ويمكن أن تحتوي على نص أو أيقونة أو صورة.
avatar-group = مجموعة الصور الرمزية
    .description = تعرض مجموعة الصور الرمزية عدة صور رمزية مكدسة معاً لتمثيل مجموعة من المستخدمين أو الكيانات.
badge = شارة
    .description = تُستخدم الشارة لإبراز حالة العنصر أو الفئة أو العدد. يمكن أن تحتوي الشارات على نص أو أرقام أو رموز، وقد يتم تصميمها باستخدام متغيرات اللون الدلالية.
button-title = زر
    .description = يمكن استخدام الزر لإرسال حدث عند الضغط عليه. عادةً ما يتم استخدامها لتشغيل إجراء.
calendar = تقويم
    .description = يسمح التقويم للمستخدمين بتحديد التواريخ والتنقل عبر الأشهر والسنوات.
card = بطاقة
    .description = البطاقة عبارة عن سطح يجمع المحتوى والإجراءات ذات الصلة على موضوع واحد.
chip = شريحة
    .description = يمكن استخدام الشريحة لإعلام المستخدم بحالة بيانات معينة.
collapsible = قابل للطي
    .description = يعرض العنصر القابل للطي أو يخفي محتواه عند الضغط على الرأس.
combobox = صندوق مدمج
    .description = يجمع الصندوق المدمج إدخال نصي مع قائمة من الخيارات.
divider = فاصل
    .description = الفاصل عبارة عن خط يفصل المحتوى إلى أقسام متميزة.
dropdown = قائمة منسدلة
    .description = تعرض القائمة المنسدلة قائمة بالخيارات التي يمكن فتحها وإغلاقها.
element = عنصر
    .description = العنصر عبارة عن عرض خام بدون محتوى مدمج. إنه كتلة بناء مرنة للتخطيطات المخصصة والأشكال الزخرفية والمناطق الإحاطة المصممة.
grid = شبكة
    .description = تنظم الشبكة العناصر الفرعية في صفوف وأعمدة محددة بأحجام مسارات صريحة.
hstack = مكدس أفقي
    .description = يمكن استخدام حاوية المكدس الأفقي لترتيب العروض في صف.
image = صورة
    .description = يعرض عرض الصورة صورة من مدير الموارد.
knob = زر دوار
    .description = الزر الدوار عبارة عن عنصر تحكم دوار يسمح للمستخدمين بتحديد قيمة.
label = تسمية
    .description = يمكن استخدام التسمية لعرض سلسلة نصية.
list = قائمة
    .description = تعرض القائمة العناصر في حاوية قابلة للتمرير.
markdown = Markdown
    .description = يعرض عرض Markdown مجموعة فرعية من Markdown في الواجهة.
menu = قائمة
    .description = تعرض القائمة قائمة بالخيارات التي يمكن تحديدها.
menu-bar = شريط القوائم
    .description = يحتوي شريط القوائم على عناصر قائمة متعددة للملاحة والإجراءات.
popover = نافذة منبثقة
    .description = تعرض النافذة المنبثقة محتوى عائم مرتبط بعنصر محفز. يتم إغلاقها عند نقل التركيز بعيداً.
progress-bar = شريط التقدم
    .description = يعرض شريط التقدم تقدم عملية أو مهمة.
radiobutton = زر الخيار
    .description = يمكن استخدام زر الخيار لتحديد خيار من مجموعة من الخيارات.
rating = تصنيف
    .description = يسمح عنصر التحكم بالتصنيف للمستخدمين بتقييم العناصر على مقياس.
resizable = قابل لتغيير الحجم
    .description = يلف العنصر القابل لتغيير الحجم عرضاً بمقبض قابل للسحب يسمح للمستخدم بتغيير حجمه. انقر نقراً مزدوجاً على المقبض للإعادة.
scrollview = عرض قابل للتمرير
    .description = يوفر العرض القابل للتمرير منطقة قابلة للتمرير لمحتواه.
select = تحديد
    .description = عرض يسمح للمستخدم بتحديد خيار من قائمة.
slider = منزلق
    .description = يسمح المنزلق للمستخدم بتحديد قيمة من نطاق مستمر عن طريق سحب الإبهام على طول المسار.
spinbox = صندوق الدوران
    .description = يسمح صندوق الدوران للمستخدمين بتحديد قيمة رقمية بالنقر على أزرار الزيادة / الإنقاص أو الكتابة.
switch = مفتاح
    .description = يبدل المفتاح بين حالتين.
svg = Svg
    .description = يعرض عرض SVG رسومات متجهة قابلة للتطوير.
tabview = عرض التبويبات
    .description = يعرض عرض التبويبات عدة علامات تبويب يمكن الانتقال بينها.
table = جدول
    .description = يعرض الجدول بيانات جدولية مع أعمدة قابلة للفرز والتغيير الحجم وتحديد الصفوف. انقر على رأس العمود للفرز. انقر على صف لتحديده.
toggle-button = زر بديل
    .description = يبدل زر البديل بين حالتين عند النقر عليه.
tooltip = تلميح الأداة
    .description = يعرض تلميح الأداة معلومات إضافية بالقرب من عرضه الهدف. يتم تشغيل تلميحات الأدوات عند التمرير أو التركيز على عرض الهدف والإغلاق عند الإزالة أو حركة الماوس خارج الهدف أو حاوية تلميح الأداة.
virtual-list = قائمة افتراضية
    .description = تعرض القائمة الافتراضية العناصر المرئية فقط، مما يحافظ على استهلاك الذاكرة والتكلفة المنخفضة للعظم الكبيرة.
virtual-table = جدول افتراضي
    .description = يعرض الجدول الافتراضي الصفوف المرئية فقط لمجموعات البيانات الكبيرة، مما يحافظ على استهلاك الذاكرة والتكلفة المنخفضة للعظم. تعرض هذه النسخة التجريبية 500 صف.
xypad = وسادة XY
    .description = توفر وسادة XY سطح إدخال ثنائي الأبعاد للتحكم في قيمتين في نفس الوقت عن طريق السحب.
vstack = مكدس عمودي
    .description = يمكن استخدام حاوية المكدس العمودي لترتيب العروض في عمود.
zstack = مكدس متراص
    .description = يمكن استخدام حاوية المكدس المتراص لتكديس العروض فوق بعضها البعض.
markdown-rendering = عرض Markdown
basic-table = جدول أساسي
virtual-table-500-row = جدول افتراضي بـ 500 صف

